{
  "manifest_version": 3,
  "name": "WatchSync — Watch Party",
  "version": "1.0.0",
  "description": "Watch Netflix, Prime Video, Disney+ Hotstar, YouTube and Crunchyroll in perfect sync with friends, with an integrated live chat. No login required.",
  "minimum_chrome_version": "102",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/*",
    "*://*.hotstar.com/*",
    "*://*.youtube.com/*",
    "*://*.crunchyroll.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WatchSync — Start or join a watch party",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.hotstar.com/*",
        "*://*.youtube.com/*",
        "*://*.crunchyroll.com/*"
      ],
      "js": ["capture.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.hotstar.com/*",
        "*://*.youtube.com/*"
      ],
      "js": [
        "injection_hosts/netflix.js",
        "injection_hosts/prime.js",
        "injection_hosts/hotstar.js",
        "injection_hosts/youtube.js",
        "injection_hosts/crunchyroll.js",
        "avatars.js",
        "emoji-panel.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "js": [
        "injection_hosts/netflix.js",
        "injection_hosts/prime.js",
        "injection_hosts/hotstar.js",
        "injection_hosts/youtube.js",
        "injection_hosts/crunchyroll.js",
        "avatars.js",
        "emoji-panel.js",
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "styles.css",
        "lib/emoji-data.json"
      ],
      "matches": [
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.hotstar.com/*",
        "*://*.youtube.com/*",
        "*://*.crunchyroll.com/*"
      ]
    }
  ]
}
